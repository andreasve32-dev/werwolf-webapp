# ══════════════════════════════════════════════════════════════
#  WERWOLF — .htaccess  (Document Root: /var/www/html)
# ══════════════════════════════════════════════════════════════
#
#  Zugriffsmatrix:
#  ÖFFENTLICH    → index.php, assets/*
#  APP/          → game.php, deaths.php, roles.php, stats.php, faq.php,
#                   logout.php (alle: Auth::requireLogin
#                   bzw. requireAdmin); register.php, datenschutz.php,
#                   impressum.php, nutzungsbedingungen.php (öffentlich, kein
#                   Login nötig — aus rechtlichen Gründen jederzeit erreichbar)
#  NUR ADMIN     → admin/*                             (PHP: Auth::requireAdmin)
#  NUR AJAX      → api/*                               (PHP: Auth::requireLogin + DB-Check)
#  GESPERRT (403)→ config/, core/, templates/, db/
#  GESPERRT (403)→ *.sql, *.md, *.log, *.bak, .htaccess, .env
# ══════════════════════════════════════════════════════════════

# ── Verzeichnislisten überall deaktivieren ───────────────────
Options -Indexes

# ── Standard-Startseite ──────────────────────────────────────
DirectoryIndex index.php

# ── Interne Ordner sperren (403) ─────────────────────────────
# Diese Ordner enthalten PHP-Klassen, SQL-Schemata, Konfiguration
# und Templates — niemals per HTTP erreichbar.
<IfModule mod_alias.c>
  RedirectMatch 403 ^/(config|core|templates|db|uploads)(/|$)
</IfModule>

# ── Alte Root-URLs auf app/ umleiten (Umzug 2026-07-04) ───────
# Seiten liegen jetzt unter app/ — alte Bookmarks/PWA-Icons/Links
# sollen trotzdem weiterhin funktionieren.
<IfModule mod_alias.c>
  RedirectMatch 301 ^/game\.php$                  /app/game.php
  RedirectMatch 301 ^/deaths\.php$                /app/deaths.php
  RedirectMatch 301 ^/roles\.php$                  /app/roles.php
  RedirectMatch 301 ^/stats\.php$                  /app/stats.php
  RedirectMatch 301 ^/faq\.php$                    /app/faq.php
  RedirectMatch 301 ^/logout\.php$                /app/logout.php
  RedirectMatch 301 ^/register\.php$              /app/register.php
  RedirectMatch 301 ^/datenschutz\.php$            /app/datenschutz.php
  RedirectMatch 301 ^/impressum\.php$              /app/impressum.php
  RedirectMatch 301 ^/nutzungsbedingungen\.php$    /app/nutzungsbedingungen.php
</IfModule>

# ── Sensible Dateitypen sperren ──────────────────────────────
<FilesMatch "\.(sql|md|log|bak|tmp|sh|env|htpasswd|ini|orig|swp)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>

# .htaccess und .htpasswd selbst vor Lesezugriff schützen
<Files ~ "^\.ht">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</Files>

# ── Cache deaktivieren (alle Ressourcen) ─────────────────────
<IfModule mod_headers.c>
  Header always set Cache-Control "no-cache, no-store, must-revalidate"
  Header always set Pragma        "no-cache"
  Header always set Expires       "0"
</IfModule>

# ── Sicherheits-Header ───────────────────────────────────────
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options  "nosniff"
  Header always set X-Frame-Options         "SAMEORIGIN"
  Header always set Referrer-Policy         "strict-origin-when-cross-origin"
  Header always set X-XSS-Protection        "1; mode=block"
  Header unset X-Powered-By
  Header always unset X-Powered-By
</IfModule>

# ── Service Worker: Scope trotz assets/js/-Speicherort auf "/" erlauben ──
# Ohne diesen Header würde der Browser register(..., {scope:'/'}) ablehnen,
# weil sw.js nicht mehr im Wurzelverzeichnis liegt.
<IfModule mod_headers.c>
  <Files "sw.js">
    Header set Service-Worker-Allowed "/"
  </Files>
</IfModule>

# ── PHP-Version nicht preisgeben ─────────────────────────────
<IfModule mod_php.c>
  php_flag expose_php Off
</IfModule>

# ── Zeichensatz für Textdateien ──────────────────────────────
<IfModule mod_mime.c>
  AddCharset utf-8 .css .js .php .html .htm .json
</IfModule>
